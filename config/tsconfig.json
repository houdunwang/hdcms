{
	"include": [
		"config/**/*",
		"core/**/*",
		"tsdown.config.ts"
	],
	"exclude": [
		"node_modules",
		"**/*.spec.ts",
	],
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"lib": [
			"ES2022",
			"DOM",
			"DOM.Iterable"
		],
		"paths": {
			"@/*": [
				"./src/*"
			],
		},
		"outDir": "./dist",
		"rootDir": "./",
		"strict": true,
		"skipLibCheck": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedSideEffectImports": true,
		"verbatimModuleSyntax": true,
		"noEmit": false,
		"declaration": true,
		"emitDeclarationOnly": true,
		"allowImportingTsExtensions": true,
		"declarationMap": false,
		// "isolatedDeclarations": true
	}
}