{
	"include": [
		"**/*.ts",
		"**/*.tsx",
		"**/*.d.ts"
	],
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"lib": [
			"ES2022",
			"DOM",
			"DOM.Iterable"
		],
		"baseUrl": ".",
		"paths": {
			"@/*": [
				"./src/*"
			],
			"@core/*": [
				"./core/*"
			]
		},
		"outDir": "./dist",
		"rootDir": "./",
		"strict": true,
		"skipLibCheck": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedSideEffectImports": true,
		"verbatimModuleSyntax": true,
		"noEmit": false,
		"declaration": true,
		"emitDeclarationOnly": true,
		"declarationMap": true
	}
}