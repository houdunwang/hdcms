{
  "name": "@hdcms/wechat",
  "description": "JS版本微信管理SDK",
  "module": "./src/index.ts",
  "version": "1.0.1",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "向军大叔",
    "email": "2300071698@qq.com",
    "url": "https://www.houdunyun.com"
  },
  "homepage": "https://www.houdunyun.com",
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "",
    "format": "prettier --write \"./**/*.{js,json}\""
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "publishConfig": {
    "main": "./dist/index.mjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "default": "./dist/index.mjs"
      },
      "./*": {
        "types": "./dist/*.d.mts",
        "import": "./dist/*.mjs",
        "default": "./dist/*.mjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "wechat",
    "后盾云"
  ],
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "fast-xml-parser": "^5.3.5",
    "ofetch": "^1.5.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "prettier": "^3.5.3",
    "tsdown": "^0.21.1",
    "typescript": "~5.8"
  }
}