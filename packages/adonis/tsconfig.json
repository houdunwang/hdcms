{
  "extends": "@adonisjs/tsconfig/tsconfig.package.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "#/app/*": [
        "../../apps/admin/app/*"
      ],
      "#/core/*": [
        "./*"
      ],
      "#start/*": [
        "../../apps/admin/start/*"
      ],
      "#config/*": [
        "../../apps/admin/config/*"
      ],
      "#database/*": [
        "../../apps/admin/database/*"
      ],
      "#*": [
        "../../apps/admin/app/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "../../apps/admin/providers/api_provider.ts",
    "../../apps/admin/config/auth.ts",
    "../../apps/admin/.adonisjs/server/**/*",
    "../../apps/admin/adonisrc.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}